              "    pm.expect(body.operation).to.eql('edge_detection');",
              "});",
              "",
              "pm.test('Response contains base64 image', () => {",
              "    pm.expect(body.image).to.be.a('string');",
              "    pm.expect(body.image.length).to.be.greaterThan(0);",
              "});",
              "",
              "pm.test('Response has size_bytes', () => {",
              "    pm.expect(body.size_bytes).to.be.a('number').and.to.be.greaterThan(0);",
              "});",
              "",
              "pm.test('Response time below 30 sec', () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(30000);",
